# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# X Layer Chain Configuration
# 1952 = X Layer Testnet, 196 = X Layer Mainnet
NEXT_PUBLIC_CHAIN_ID=1952

# X Layer RPC URL (optional, defaults based on chain_id)
NEXT_PUBLIC_RPC_URL=https://testrpc.xlayer.tech

# WalletConnect Project ID (get one at https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Contract addresses (update after deployment)
NEXT_PUBLIC_ESCROW_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_TOKEN=0x0000000000000000000000000000000000000000
