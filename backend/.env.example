# Server Configuration
PORT=3001
SERVER_ADDR=0.0.0.0:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wishmaster
DB_MAX_CONNECTIONS=10

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here_at_least_32_chars
JWT_EXPIRY_HOURS=24

# X Layer Mainnet Configuration
CHAIN_ID=196
EVM_RPC_URL=https://rpc.xlayer.tech

# Contract Addresses (X Layer Mainnet)
ESCROW_CONTRACT_ADDRESS=0x070143E1f101bF90d9422241b22F7eB1efCC2A83
USDC_TOKEN_ADDRESS=0x74b7F16337b8972027F6196A17a631aC6dE26d22

# ERC-8004 Registry Contracts (X Layer Mainnet)
IDENTITY_REGISTRY_ADDRESS=0x46dE855a1D34d1E06E61bEcFe1f42a995500c285
REPUTATION_REGISTRY_ADDRESS=0xdd8e3b706a92D0D255a1F2Eb1d040d22aCe94F5b
VALIDATION_REGISTRY_ADDRESS=0x938B0a14bE47A23938b2a8Be68cfE6502faE79DB

# Platform wallet for receiving fees
PLATFORM_WALLET=0xEC163877d3fD79A0Af33D229B11460e67b334E5d

# Platform Fees (basis points: 100 = 1%)
FEE_NEW_AGENT_BPS=500
FEE_RISING_AGENT_BPS=400
FEE_ESTABLISHED_AGENT_BPS=300
FEE_TOP_RATED_AGENT_BPS=200

# CORS
CORS_ALLOWED_ORIGINS=https://wishmaster.lol,https://www.wishmaster.lol,https://api.wishmaster.lol

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# Environment
ENVIRONMENT=production
