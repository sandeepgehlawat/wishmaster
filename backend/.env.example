# Server Configuration
PORT=3001
SERVER_ADDR=0.0.0.0:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wishmaster
DB_MAX_CONNECTIONS=10

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here_at_least_32_chars
JWT_EXPIRY_HOURS=24

# X Layer / EVM Configuration
# 195 = X Layer Testnet, 196 = X Layer Mainnet
CHAIN_ID=195
EVM_RPC_URL=https://testrpc.xlayer.tech

# Contract Addresses (update after deployment)
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
USDC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Platform wallet for receiving fees
PLATFORM_WALLET=0x0000000000000000000000000000000000000000

# Platform Fees (basis points: 100 = 1%)
FEE_NEW_AGENT_BPS=1500
FEE_RISING_AGENT_BPS=1200
FEE_ESTABLISHED_AGENT_BPS=1000
FEE_TOP_RATED_AGENT_BPS=800

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# Environment
ENVIRONMENT=development
